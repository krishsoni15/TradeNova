# ============================================
# TradeNova — .gitignore
# ============================================

# Dependencies
node_modules/
.pnp/
.pnp.js

# Next.js
tradenova/.next/
tradenova/out/

# Build
dist/
build/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
backend/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
venv/
.venv/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
*.log
.vercel
